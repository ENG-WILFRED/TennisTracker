generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(uuid())
  username     String     @unique
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  firstName    String
  lastName     String
  photo        String?
  gender       String?
  dateOfBirth  DateTime?
  nationality  String?
  bio          String?
  latitude     Float?
  longitude    Float?
  city         String?
  country      String      @default("Kenya")
  acceptedTermsAt DateTime?
  termsDeclineCount Int @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  memberships  Membership[]
  player       Player?
  referee      Referee?
  spectator    Spectator?
  staff        Staff?
  tasksAdminAssigned Task[]          @relation("TaskAssignmentAdmin")
  tasksSubmitted     TaskSubmission[] @relation("TaskSubmissions")
  tasksReviewed      TaskSubmission[] @relation("TaskSubmissionReviews")
  taskHistoryEntries TaskHistory[]
  resourceRequests   ResourceRequest[] @relation("ResourceRequests")
  resourceApprovals  ResourceRequest[] @relation("ResourceApprovals")
  bugReports   BugReport[]
  // Guardian relationships
  guardianOf   Guardian[] @relation("Guardian")
  guardians    Guardian[] @relation("Dependent")
  // Parent relationships for invoices and ownership
  parentInvoices InvoiceModel[] @relation("InvoiceParent")
  parentTransfers OwnershipTransfer[] @relation("OwnershipTransferParent")

  @@index([createdAt])
  @@index([latitude, longitude])
  @@index([city])
}

model Membership {
  id          String      @id @default(uuid())
  userId      String
  orgId       String
  role        String      // 'player', 'coach', 'referee', 'staff', 'admin', 'finance_officer'
  status      String      @default("pending") // 'pending', 'accepted', 'rejected', 'suspended'
  joinedAt    DateTime    @default(now())
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([userId])
  @@index([orgId])
  @@index([status])
}

model MembershipInvitation {
  id          String      @id @default(uuid())
  orgId       String
  email       String
  role        String      // 'player', 'coach', 'referee', 'staff', 'admin', 'finance_officer'
  status      String      @default("pending") // 'pending', 'accepted', 'rejected'
  invitedBy   String?
  invitedAt   DateTime    @default(now())
  expiresAt   DateTime?
  acceptedAt  DateTime?
  acceptedBy  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email, role])
  @@index([orgId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
}

model Guardian {
  id             String      @id @default(uuid())
  guardianId     String      // User ID of the parent/guardian
  dependentId    String      // User ID of the child/dependent
  relationship   String      // 'parent', 'guardian', 'legal_guardian'
  isApproved     Boolean     @default(false)
  approvedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  guardian       User        @relation("Guardian", fields: [guardianId], references: [id], onDelete: Cascade)
  dependent      User        @relation("Dependent", fields: [dependentId], references: [id], onDelete: Cascade)

  @@unique([guardianId, dependentId])
  @@index([guardianId])
  @@index([dependentId])
  @@index([isApproved])
}

model Player {
  matchesPlayed              Int                         @default(0)
  matchesWon                 Int                         @default(0)
  matchesLost                Int                         @default(0)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  isClub                     Boolean                     @default(false)
  organizationId             String?
  userId                     String                      @id
  
  @@index([createdAt])
  attendance                 Attendance[]
  chatMessages               ChatMessage[]
  chatRooms                  ChatParticipant[]
  clubMembers                ClubMember[]
  commentReactions           CommentReaction[]           @relation("comment_reactions")
  communityPosts             CommunityPost[]
  inventoryItems             InventoryItem[]
  matchesA                   Match[]                     @relation("PlayerA")
  matchesB                   Match[]                     @relation("PlayerB")
  Match                      Match[]
  ballCrewMatches            MatchBallCrew[]
  messageReactions           MessageReaction[]
  performancePoints          PerformancePoint[]
  organization               Organization?               @relation(fields: [organizationId], references: [id])
  user                       User                        @relation(fields: [userId], references: [id])
  playerBadges               PlayerBadge[]
  commentedPosts             PostComment[]
  reactions                  PostReaction[]
  staffMembers               Staff[]
  followers                  UserFollower[]              @relation("followers")
  following                  UserFollower[]              @relation("following")
  tournamentComments         TournamentComment[]
  tournamentCommentReactions TournamentCommentReaction[] @relation("tournament_comment_reactions")
  activities                 OrganizationActivity[]
  ruleAppeals                RuleAppeal[]
  providerProfile            ProviderProfile?
  serviceBookings            ServiceBooking[]
  courtComments              CourtComment[]
  courtComplaints            CourtComplaint[]
  coachSessions              CoachSession[]             @relation("CoachSessionsAsPlayer")
  sessionBookings            SessionBooking[]           @relation("SessionBookings")
  coachRelationships         CoachPlayerRelationship[]  @relation("CoachPlayers")
  coachSessionReviews        CoachSessionReview[]       @relation("CoachSessionReviews")
  playerReports              PlayerReport[]
  invoices                   Invoice[]
  subscriptions              Subscription[]
  playerMetrics              PlayerMetric[]
  invoiceModels              InvoiceModel[]
  ownershipTransfers         OwnershipTransfer[]
  dailyPlayerStats           DailyPlayerStats[]

  @@index([organizationId])
}

model InventoryItem {
  id             String        @id @default(uuid())
  name           String
  count          Int           @default(0)
  condition      String?
  clubId         String?
  updatedAt      DateTime      @updatedAt
  organizationId String?
  club           Player?       @relation(fields: [clubId], references: [userId])
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Referee {
  matchesRefereed  Int             @default(0)
  ballCrewMatches  Int             @default(0)
  experience       String?
  certifications   String[]        @default([])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userId           String          @id
  refereedMatches  Match[]         @relation("Referee")
  ballCrewReferees MatchBallCrew[] @relation("BallCrewReferee")
  matchReports     MatchReport[]
  user             User            @relation(fields: [userId], references: [id])
}

model Staff {
  role                   String
  expertise              String?
  contact                String?
  employedById           String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  yearsOfExperience      Int?             @default(0)
  coachingLevel          String?
  formerPlayerBackground String?
  playerAgeGroups        String[]         @default([])
  skillLevelsTrained     String[]         @default([])
  trainingTypes          String[]         @default([])
  languagesSpoken        String[]         @default([])
  sessionDurations       Int[]            @default([30, 60, 90])
  maxStudentsPerSession  Int?             @default(1)
  courtLocations         String[]         @default([])
  bio                    String?
  coachingPhilosophy     String?
  achievements           String?
  introVideoUrl          String?
  studentCount           Int              @default(0)
  isVerified             Boolean          @default(false)
  isActive               Boolean          @default(true)
  isDeleted              Boolean          @default(false)
  ownerId                String?
  organizationId         String?
  userId                 String           @id
  auditLogs              AuditLog[]
  availability           Availability[]
  certifications         Certification[]
  pricing                CoachPricing?
  reviews                CoachReview[]
  specializations        Specialization[]
  employedBy             Player?          @relation(fields: [employedById], references: [userId])
  organization           Organization?    @relation(fields: [organizationId], references: [id])
  user                   User             @relation(fields: [userId], references: [id])
  tasks                  EventTask[]
  sessions               CoachSession[]   @relation("CoachSessions")
  players                CoachPlayerRelationship[] @relation("CoachPlayers")
  wallet                 CoachWallet?     @relation("CoachWallet")
  payouts                CoachPayout[]    @relation("CoachPayouts")
  stats                  CoachStats?      @relation("CoachStats")
  dailyStats             CoachDailyStats[] @relation("CoachDailyStats")
  sessionReviews         CoachSessionReview[] @relation("CoachSessionReviews")
  activities             Activity[]       @relation("Activities")
  assignedTasks          Task[]           @relation("TaskAssignmentStaff")
  progressUpdates        ProgressUpdate[]
  coachReports           CoachReport[]
  earnings               CoachEarning[]
  availabilities         CoachAvailability[]
  recurringSessions      RecurringSession[]    @relation("RecurringCoachSessions")
  coachPerfSummaries     CoachPerformanceSummary[] @relation("CoachPerformanceSummaries")

  @@index([organizationId])
  @@index([employedById])
  @@index([isActive])
  @@index([createdAt])
}

model Spectator {
  userId    String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Organization {
  id                      String                   @id @default(uuid())
  name                    String                   @unique
  slug                    String?                  @unique
  description             String?
  address                 String?
  city                    String?
  country                 String?
  phone                   String?
  email                   String?
  logo                    String?
  primaryColor            String?
  createdBy               String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  activityScore           Int                      @default(0)
  playerDevScore          Int                      @default(0)
  rating                  Float?                   @default(0)
  ratingCount             Int                      @default(0)
  tournamentEngScore      Int                      @default(0)
  verifiedBadge           Boolean                  @default(false)
  memberships             Membership[]
  invitations             MembershipInvitation[]
  announcements           ClubAnnouncement[]
  tournamentAnnouncements TournamentAnnouncement[] @relation("tournamentAnnouncements")
  events                  ClubEvent[]
  finances                ClubFinance[]
  members                 ClubMember[]
  ratings                 ClubRating[]
  courts                  Court[]
  bookings                CourtBooking[]
  inventory               InventoryItem[]
  membershipTiers         MembershipTier[]         @relation("membershipTiers")
  orgBadges               OrganizationBadge[]
  roles                   OrganizationRole[]
  players                 Player[]
  rankings                PlayerRanking[]
  challenges              RankingChallenge[]       @relation("challenges")
  permissions             RolePermission[]
  staff                   Staff[]
  tournamentBrackets      TournamentBracket[]
  matches                 TournamentMatch[]
  activities              OrganizationActivity[]
  ruleAppeals             RuleAppeal[]
  services                Service[]
  providerProfiles        ProviderProfile[]
  tasks                   EventTask[]
  coachSessions           CoachSession[]           @relation("CoachSessions")
  taskTemplates           TaskTemplate[]           @relation("TaskTemplates")
  assignedTasks           Task[]                   @relation("OrganizationTasks")
  communityPosts          CommunityPost[]
  // Operating Model Relations
  playerMetrics           PlayerMetric[]
  recommendations         Recommendation[]
  revenues                OrgRevenue[]
  payoutCycles            CoachPayoutCycle[]
  availability            CoachAvailability[]
  messages                Message[]
  notifications           Notification[]
  // Reporting & Analytics
  playerReports           PlayerReport[]
  parentReports           ParentReport[]
  coachReports            CoachReport[]
  analytics               OrgAnalytics?
  invoices                Invoice[]
  paymentMethods          PaymentMethod[]
  subscriptions           Subscription[]
  notificationTriggers    NotificationTrigger[]
  announcementMessages    Announcement[]
  // Event system
  eventLogs               EventLog[]
  ledgerEntries           LedgerEntry[]
  paymentTransactions     PaymentTransaction[]
  invoiceModels           InvoiceModel[]          @relation("InvoiceModels")
  coachPerformanceSummaries CoachPerformanceSummary[]
  metricsSnapshot         OrgMetricsSnapshot?
  recurringSessionPatterns RecurringSession[]     @relation("RecurringSessions")
  metricWeights           MetricWeight[]
  recommendationConfigs   RecommendationConfig[]
  ownershipTransfers      OwnershipTransfer[]
  notificationLogs        NotificationLogModel[]
  dailyPlayerStats        DailyPlayerStats[]

  @@index([createdAt])
  @@index([slug])
}

model ProviderProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  businessName   String
  categories     String[] @default([])
  phone          String
  description    String
  organizationId String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           Player           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  services       Service[]
  ServiceBooking ServiceBooking[]

  @@index([organizationId])
}

model Service {
  id             String   @id @default(uuid())
  providerId     String?
  organizationId String?
  tournamentId   String?
  name           String
  description    String
  category       String
  sourceType     String   @default("internal")
  contextType    String   @default("both")
  price          Float?
  location       String?
  externalLink   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  provider     ProviderProfile? @relation(fields: [providerId], references: [id], onDelete: Cascade)
  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tournament   ClubEvent?       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  bookings     ServiceBooking[]
  tasks        EventTask[]

  @@index([providerId])
  @@index([organizationId])
  @@index([tournamentId])
}

model ServiceBooking {
  id          String   @id @default(uuid())
  userId      String
  serviceId   String
  providerId  String?
  contextType String
  contextId   String
  note        String?
  status      String   @default("requested")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     Player           @relation(fields: [userId], references: [userId], onDelete: Cascade)
  service  Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  provider ProviderProfile? @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([serviceId])
  @@index([providerId])
}

model Certification {
  id        String    @id @default(uuid())
  staffId   String
  name      String
  issuer    String?
  issuedAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  staff     Staff     @relation(fields: [staffId], references: [userId], onDelete: Cascade)

  @@unique([staffId, name])
}

model Specialization {
  id           String   @id @default(uuid())
  staffId      String
  name         String
  level        String?
  yearsOfFocus Int?
  createdAt    DateTime @default(now())
  staff        Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)

  @@unique([staffId, name])
}

model Availability {
  id        String   @id @default(uuid())
  staffId   String
  dayOfWeek Int
  startTime String
  endTime   String
  createdAt DateTime @default(now())
  staff     Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)

  @@unique([staffId, dayOfWeek, startTime])
}

model CoachPricing {
  id                   String   @id @default(uuid())
  staffId              String   @unique
  pricePerSession      Float
  currency             String   @default("USD")
  package3Sessions     Float?
  package10Sessions    Float?
  juniorDiscount       Float?   @default(0)
  groupSessionDiscount Float?   @default(0)
  commissionRate       Float?   @default(0)
  paymentMethods       String[] @default(["credit_card", "bank_transfer"])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  staff                Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
}

model CoachReview {
  id         String   @id @default(uuid())
  staffId    String
  playerId   String
  rating     Float
  reviewText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  staff      Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)

  @@unique([staffId, playerId])
}

model AuditLog {
  id          String   @id @default(uuid())
  staffId     String
  action      String
  createdAt   DateTime @default(now())
  field       String?
  newValue    String?
  oldValue    String?
  performedBy String?
  staff       Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
}

model Match {
  id        String          @id @default(uuid())
  round     Int
  playerAId String
  playerBId String
  refereeId String?
  winnerId  String?
  score     String?
  createdAt DateTime        @default(now())
  group     String?
  playerA   Player          @relation("PlayerA", fields: [playerAId], references: [userId])
  playerB   Player          @relation("PlayerB", fields: [playerBId], references: [userId])
  referee   Referee?        @relation("Referee", fields: [refereeId], references: [userId])
  winner    Player?         @relation(fields: [winnerId], references: [userId])
  ballCrew  MatchBallCrew[]
  report    MatchReport?

  @@index([refereeId])
  @@index([winnerId])
  @@index([createdAt])
}

model MatchReport {
  id            String   @id @default(uuid())
  matchId       String   @unique
  refereeId     String
  pdfContent    String   @db.Text
  fileName      String
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  referee       Referee  @relation(fields: [refereeId], references: [userId], onDelete: Cascade)

  @@index([matchId])
  @@index([refereeId])
  @@index([generatedAt])
}

model MatchBallCrew {
  id              String   @id @default(uuid())
  matchId         String
  playerId        String
  refereeId       String?
  match           Match    @relation(fields: [matchId], references: [id])
  player          Player   @relation(fields: [playerId], references: [userId])
  ballCrewReferee Referee? @relation("BallCrewReferee", fields: [refereeId], references: [userId])
}

model Badge {
  id           String        @id @default(uuid())
  name         String
  description  String
  category     String
  icon         String?
  playerBadges PlayerBadge[]
}

model PlayerBadge {
  id       String   @id @default(uuid())
  playerId String
  badgeId  String
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id])
  player   Player   @relation(fields: [playerId], references: [userId])
}

model Attendance {
  id        String   @id @default(uuid())
  playerId  String
  date      DateTime
  present   Boolean  @default(true)
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [userId])
}

model PerformancePoint {
  id        String   @id @default(uuid())
  playerId  String
  date      DateTime
  rating    Float
  points    Int
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [userId])
}

model TennisRule {
  id        String   @id @default(uuid())
  category  String
  label     String
  value     String?
  createdAt DateTime @default(now())

  @@unique([category, label])
}

model ChatRoom {
  id           String            @id @default(uuid())
  name         String
  description  String?
  isPrivate    Boolean           @default(false)
  createdBy    String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  isDM         Boolean           @default(false)
  messages     ChatMessage[]
  participants ChatParticipant[]

  @@index([isDM])
  @@index([createdAt])
  @@index([updatedAt])
}

model ChatMessage {
  id          String            @id @default(uuid())
  roomId      String
  playerId    String
  content     String
  createdAt   DateTime          @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
  isDeleted   Boolean           @default(false)
  replyToId   String?
  updatedAt   DateTime          @updatedAt
  player      Player            @relation(fields: [playerId], references: [userId])
  replyTo     ChatMessage?      @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     ChatMessage[]     @relation("MessageReplies")
  room        ChatRoom          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reactions   MessageReaction[]

  @@index([roomId, createdAt])
}

model MessageReaction {
  id        String      @id @default(uuid())
  messageId String
  playerId  String
  emoji     String
  createdAt DateTime    @default(now())
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  player    Player      @relation(fields: [playerId], references: [userId])

  @@unique([messageId, playerId, emoji])
  @@index([messageId])
}

model ChatParticipant {
  id        String   @id @default(uuid())
  roomId    String
  playerId  String
  isOnline  Boolean  @default(false)
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [userId])
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, playerId])
  @@index([roomId])
  @@index([playerId])
  @@index([isOnline])
  @@index([playerId, lastSeen])
}

model Court {
  id                    String            @id @default(uuid())
  organizationId        String
  name                  String
  courtNumber           Int
  surface               String
  indoorOutdoor         String            @default("outdoor")
  lights                Boolean           @default(false)
  status                String            @default("available")
  maintenedUntil        DateTime?
  // Extended fields
  description           String?
  imageUrl              String?           // Primary image URL
  latitude              Float?
  longitude             Float?
  address               String?
  city                  String?
  country               String?
  width                 Float?
  length                Float?
  maxCapacity           Int?
  peakHourStart         String?
  peakHourEnd           String?
  peakPrice             Float?
  offPeakPrice          Float?
  amenities             String[]          @default([])
  rules                 String[]          @default([])
  availableDays         String[]          @default([])
  openTime              String?
  closeTime             String?
  nextMaintenanceDate   DateTime?
  lastInspectionDate    DateTime?
  yearBuilt             Int?
  renovationYear        Int?
  contactEmail          String?
  contactPhone          String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings              CourtBooking[]
  comments              CourtComment[]
  complaints            CourtComplaint[]
  tournamentMatches     TournamentMatch[]
  images                CourtImage[]
  coachSessions         CoachSession[]     @relation("CoachSessions")

  @@unique([organizationId, courtNumber])
  @@index([organizationId])
  @@index([status])
}

model CourtImage {
  id        String   @id @default(uuid())
  courtId   String
  data      String   @db.Text // Base64 encoded image data
  width     Int?     // Original width
  height    Int?     // Original height
  posX      Float?   @default(0) // Position X (percentage or pixels)
  posY      Float?   @default(0) // Position Y (percentage or pixels)
  scale     Float?   @default(1) // Scale factor
  order     Int      @default(0) // Display order
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  court     Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@index([courtId])
  @@index([order, courtId])
}

model CourtBooking {
  id                 String       @id @default(uuid())
  organizationId     String
  courtId            String
  memberId           String?
  playerName         String?
  startTime          DateTime
  endTime            DateTime
  bookingType        String       @default("regular")
  guestCount         Int          @default(1)
  status             String       @default("confirmed")
  price              Float?
  isPeak             Boolean      @default(false)
  cancellationReason String?
  cancelledAt        DateTime?
  rejectionReason    String?
  rejectedAt         DateTime?
  notes              String?      @default("No additional notes")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  court              Court        @relation(fields: [courtId], references: [id], onDelete: Cascade)
  member             ClubMember?  @relation(fields: [memberId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  comments           CourtComment[]
  complaints         CourtComplaint[]

  @@index([organizationId, startTime, endTime])
  @@index([status])
  @@index([courtId, startTime])
  @@index([createdAt])
}

model CourtComment {
  id            String        @id @default(uuid())
  courtId       String
  bookingId     String?
  authorId      String
  content       String
  rating        Int?          @default(5)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  court         Court         @relation(fields: [courtId], references: [id], onDelete: Cascade)
  booking       CourtBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  author        Player        @relation(fields: [authorId], references: [userId], onDelete: Cascade)

  @@index([courtId])
  @@index([bookingId])
  @@index([authorId])
  @@index([createdAt])
}

model CourtComplaint {
  id             String        @id @default(uuid())
  courtId        String
  bookingId      String?
  authorId       String
  title          String
  description    String
  category       String        // 'condition', 'maintenance', 'facility', 'other'
  severity       String        @default("medium") // 'low', 'medium', 'high'
  status         String        @default("pending") // 'pending', 'resolved', 'dismissed'
  attachments    String[]      @default([])
  resolvedNotes  String?
  resolvedBy     String?
  resolvedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  court          Court         @relation(fields: [courtId], references: [id], onDelete: Cascade)
  booking        CourtBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  author         Player        @relation(fields: [authorId], references: [userId], onDelete: Cascade)

  @@index([courtId])
  @@index([bookingId])
  @@index([authorId])
  @@index([status])
  @@index([createdAt])
}

model MembershipTier {
  id                    String        @id @default(uuid())
  organizationId        String?
  name                  String        @unique
  description           String?
  monthlyPrice          Float
  benefitsJson          String?
  courtHoursPerMonth    Int?
  maxConcurrentBookings Int?          @default(3)
  discountPercentage    Float?        @default(0)
  createdAt             DateTime      @default(now())
  clubMembers           ClubMember[]  @relation("membershipTier")
  organization          Organization? @relation("membershipTiers", fields: [organizationId], references: [id])
}

model ClubMember {
  id                     String               @id @default(uuid())
  organizationId         String
  playerId               String
  tierId                 String?
  joinDate               DateTime             @default(now())
  expiryDate             DateTime?
  autoRenew              Boolean              @default(true)
  paymentStatus          String               @default("active")
  outstandingBalance     Float                @default(0)
  attendanceCount        Int                  @default(0)
  lastAttendance         DateTime?
  role                   String               @default("member")
  suspensionReason       String?
  suspendedUntil         DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  player                 Player               @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  membershipTier         MembershipTier?      @relation("membershipTier", fields: [tierId], references: [id])
  bookings               CourtBooking[]
  eventRegistrations     EventRegistration[]
  waitlistItems          EventWaitlist[]
  financeTransactions    FinanceTransaction[]
  paymentReminders       PaymentReminder[]
  rankings               PlayerRanking[]
  challengesAsChallenger RankingChallenge[]   @relation("challenger")
  challengesAsOpponent   RankingChallenge[]   @relation("opponent")
  tournamentMatchesA     TournamentMatch[]    @relation("matchPlayerA")
  tournamentMatchesB     TournamentMatch[]    @relation("matchPlayerB")
  amenityBookings        AmenityBooking[]

  @@unique([organizationId, playerId, role])
  @@index([organizationId])
  @@index([playerId])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([organizationId, paymentStatus])
}

model PlayerRanking {
  id             String       @id @default(uuid())
  organizationId String
  memberId       String
  weekNumber     Int
  year           Int
  currentRank    Int
  previousRank   Int?
  ratingPoints   Int
  matchesWon     Int          @default(0)
  matchesLost    Int          @default(0)
  winRate        Float        @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  member         ClubMember   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, memberId, weekNumber, year])
}

model RankingChallenge {
  id             String        @id @default(uuid())
  organizationId String?
  challengerId   String
  opponentId     String
  challengeDate  DateTime
  matchDate      DateTime?
  status         String        @default("pending")
  winnerId       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  challenger     ClubMember    @relation("challenger", fields: [challengerId], references: [id])
  opponent       ClubMember    @relation("opponent", fields: [opponentId], references: [id])
  organization   Organization? @relation("challenges", fields: [organizationId], references: [id])
}

model ClubEvent {
  id                   String                   @id @default(uuid())
  organizationId       String
  name                 String
  description          String?
  eventType            String
  startDate            DateTime
  endDate              DateTime?
  registrationCap      Int                      @default(64)
  registrationDeadline DateTime
  location             String?
  prizePool            Float?
  entryFee             Float?
  rules                String?
  instructions         String?
  eatingAreas          String?
  sleepingAreas        String?
  courtInfo            String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  organization         Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  registrations        EventRegistration[]
  reminders            EventReminder[]          @relation("reminders")
  paymentReminders     PaymentReminder[]
  waitlist             EventWaitlist[]
  bracket              TournamentBracket?
  matches              TournamentMatch[]
  amenities            EventAmenity[]
  tournamentComments   TournamentComment[]
  announcements        TournamentAnnouncement[] @relation("announcements")
  ruleAppeals          RuleAppeal[]
  services             Service[]
  tasks                EventTask[]

  @@index([organizationId])
  @@index([startDate, endDate])
  @@index([createdAt])
}

model EventRegistration {
  id               String            @id @default(uuid())
  eventId          String
  memberId         String
  registeredAt     DateTime          @default(now())
  status           String            @default("registered")
  signupOrder      Int
  rejectionReason  String? // Reason why application was rejected
  event            ClubEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member           ClubMember        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  paymentReminders PaymentReminder[]

  @@unique([eventId, memberId])
}

model EventWaitlist {
  id       String     @id @default(uuid())
  eventId  String
  memberId String
  position Int
  addedAt  DateTime   @default(now())
  event    ClubEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member   ClubMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([eventId, memberId])
}

model TournamentBracket {
  id             String            @id @default(uuid())
  organizationId String
  eventId        String            @unique
  bracketType    String            @default("single_elimination")
  totalRounds    Int
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  event          ClubEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  matches        TournamentMatch[]
}

model TournamentMatch {
  id                String            @id @default(uuid())
  organizationId    String
  eventId           String
  bracketId         String
  round             Int
  matchPosition     Int
  playerAId         String?
  playerBId         String?
  scoreSetA         String?
  scoreSetB         String?
  scoreSetC         String?
  winnerId          String?
  servingPlayerId   String?
  lastResetReason   String?
  lastResetAt       DateTime?
  scheduledTime     DateTime?
  courtId           String?
  status            String            @default("pending")
  resultSubmittedAt DateTime?
  resultSubmittedBy String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  bracket           TournamentBracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  court             Court?            @relation(fields: [courtId], references: [id])
  event             ClubEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  playerA           ClubMember?       @relation("matchPlayerA", fields: [playerAId], references: [id])
  playerB           ClubMember?       @relation("matchPlayerB", fields: [playerBId], references: [id])

  @@index([round])
  @@index([playerAId])
  @@index([playerBId])
  @@index([winnerId])
  @@index([scheduledTime])
}

model ClubAnnouncement {
  id               String       @id @default(uuid())
  organizationId   String
  title            String
  message          String
  announcementType String       @default("general")
  targetRoles      String[]     @default(["member"])
  createdBy        String?
  isActive         Boolean      @default(true)
  expiresAt        DateTime?
  readBy           String[]     @default([])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TournamentAnnouncement {
  id               String       @id @default(uuid())
  eventId          String
  organizationId   String
  title            String
  message          String
  announcementType String       @default("general") // "general", "schedule", "results", "important"
  createdBy        String?
  isActive         Boolean      @default(true)
  isPublished      Boolean      @default(false)
  expiresAt        DateTime?
  readBy           String[]     @default([])
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  event            ClubEvent    @relation("announcements", fields: [eventId], references: [id], onDelete: Cascade)
  organization     Organization @relation("tournamentAnnouncements", fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([organizationId])
  @@index([createdAt])
}

model EventReminder {
  id            String    @id @default(uuid())
  eventId       String
  title         String?
  description   String?
  remindTime    DateTime?
  reminderType  String    @default("email") // email, sms, chat, notification
  isActive      Boolean   @default(true)
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  event         ClubEvent @relation("reminders", fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model PaymentReminder {
  id             String            @id @default(uuid())
  eventId        String
  memberId       String
  registrationId String
  reminderType   String            @default("payment") // "payment", "confirmation", "urgency"
  message        String?
  sentAt         DateTime?
  isRead         Boolean           @default(false)
  isResolved     Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  event          ClubEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member         ClubMember        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  registration   EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([memberId])
  @@index([isRead])
}

model ClubFinance {
  id                  String               @id @default(uuid())
  organizationId      String
  month               Int
  year                Int
  membershipRevenue   Float                @default(0)
  courtBookingRevenue Float                @default(0)
  coachCommissions    Float                @default(0)
  eventRevenue        Float                @default(0)
  totalRevenue        Float                @default(0)
  totalExpenses       Float                @default(0)
  netProfit           Float                @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactionRecords  FinanceTransaction[]

  @@unique([organizationId, month, year])
}

model FinanceTransaction {
  id              String      @id @default(uuid())
  financeId       String
  description     String
  category        String
  amount          Float
  transactionType String      @default("credit")
  memberId        String?
  recordedBy      String?
  createdAt       DateTime    @default(now())
  finance         ClubFinance @relation(fields: [financeId], references: [id], onDelete: Cascade)
  relatedToMember ClubMember? @relation(fields: [memberId], references: [id])
}

model PaymentRecord {
  id                    String   @id @default(uuid())
  userId                String
  eventId               String?
  bookingType           String
  amount                Float
  currency              String
  provider              String
  providerStatus        String   @default("pending")
  providerTransactionId String?
  checkoutUrl           String?
  callbackUrl           String?
  cancelUrl             String?
  metadata              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([eventId])
  @@index([providerStatus])
  @@index([callbackUrl])
  @@index([cancelUrl])
  @@index([createdAt])
}

model OrganizationRole {
  id             String           @id @default(uuid())
  organizationId String
  name           String
  description    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permissions    RolePermission[]

  @@unique([organizationId, name])
}

model RolePermission {
  id             String           @id @default(uuid())
  organizationId String
  roleId         String
  permissionName String
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrganizationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionName])
}

model OrganizationBadge {
  id              String       @id @default(uuid())
  organizationId  String
  badgeName       String
  badgeType       String       @default("custom")
  achievementDate DateTime     @default(now())
  createdAt       DateTime     @default(now())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ClubRating {
  id             String        @id @default(uuid())
  organizationId String?
  ratedBy        String?
  rating         Float
  category       String?
  comment        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([ratedBy])
  @@index([createdAt])
}

model CommunityPost {
  id             String         @id @default(uuid())
  authorId       String
  content        String
  visibility     String?        @default("public")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  type           String         @default("post")
  tournamentId   String?
  organizationId String?
  shareCount     Int            @default(1)
  author         Player         @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  comments       PostComment[]
  likes          PostReaction[]

  @@index([authorId])
  @@index([createdAt])
  @@index([tournamentId])
  @@index([organizationId])
}

model PostComment {
  id              String            @id @default(uuid())
  postId          String
  authorId        String
  content         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  parentCommentId String?
  reactions       CommentReaction[]
  author          Player            @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  parentComment   PostComment?      @relation("comment_replies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         PostComment[]     @relation("comment_replies")
  post            CommunityPost     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
  @@index([parentCommentId])
  @@index([createdAt])
}

model TournamentComment {
  id              String                      @id @default(uuid())
  eventId         String
  authorId        String
  content         String
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  parentCommentId String?
  author          Player                      @relation(fields: [authorId], references: [userId], onDelete: Cascade)
  parentComment   TournamentComment?          @relation("tournament_comment_replies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies         TournamentComment[]         @relation("tournament_comment_replies")
  event           ClubEvent                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reactions       TournamentCommentReaction[]

  @@index([eventId])
  @@index([authorId])
  @@index([parentCommentId])
}

model TournamentCommentReaction {
  id                  String            @id @default(uuid())
  tournamentCommentId String
  userId              String
  type                String            @default("like")
  createdAt           DateTime          @default(now())
  comment             TournamentComment @relation(fields: [tournamentCommentId], references: [id], onDelete: Cascade)
  user                Player            @relation("tournament_comment_reactions", fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([tournamentCommentId, userId])
  @@index([tournamentCommentId])
  @@index([userId])
}

model CommentReaction {
  id        String      @id @default(uuid())
  commentId String
  userId    String
  type      String      @default("like")
  createdAt DateTime    @default(now())
  comment   PostComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      Player      @relation("comment_reactions", fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
}

model PostReaction {
  id        String        @id @default(uuid())
  postId    String
  userId    String
  type      String        @default("like")
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      Player        @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model UserFollower {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    Player   @relation("followers", fields: [followerId], references: [userId], onDelete: Cascade)
  following   Player   @relation("following", fields: [followingId], references: [userId], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model EventAmenity {
  id             String           @id @default(uuid())
  eventId        String
  name           String
  type           String // 'eating', 'sleeping', 'parking', etc.
  description    String?
  capacity       Int?
  price          Float?
  availableFrom  DateTime?
  availableUntil DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  event          ClubEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings       AmenityBooking[]

  @@index([eventId])
}

model AmenityBooking {
  id        String       @id @default(uuid())
  amenityId String
  memberId  String?
  guestName String?
  startTime DateTime
  endTime   DateTime
  status    String       @default("confirmed")
  price     Float?
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  amenity   EventAmenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  member    ClubMember?  @relation(fields: [memberId], references: [id])

  @@index([amenityId])
  @@index([memberId])
}

model OrganizationActivity {
  id             String       @id @default(uuid())
  organizationId String
  playerId       String
  action         String
  details        Json
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  player         Player       @relation(fields: [playerId], references: [userId], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([playerId])
}

model RuleAppeal {
  id             String       @id @default(uuid())
  userId         String
  eventId        String
  organizationId String
  ruleCategory   String? // For global rules
  ruleLabel      String? // For global rules
  appealText     String
  status         String       @default("pending") // "pending", "approved", "denied"
  responseText   String?
  respondedBy    String?
  respondedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  event          ClubEvent    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           Player       @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([eventId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model EventTask {
  id             String       @id @default(uuid())
  eventId        String?
  serviceId      String?
  staffUserId    String?
  organizationId String
  title          String
  description    String?
  role           String       // Role of the person assigned (Coach, Referee, etc.)
  responsibility String?      // Detailed responsibility description
  status         String       @default("pending") // "pending", "accepted", "in_progress", "completed", "rejected", "cancelled"
  priority       String       @default("medium") // "low", "medium", "high"
  rejectionReason String?     // Reason for task rejection
  dueDate        DateTime?
  completedAt    DateTime?
  completedBy    String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  event          ClubEvent?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  service        Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedTo     Staff?       @relation(fields: [staffUserId], references: [userId], onDelete: SetNull)

  @@index([eventId])
  @@index([organizationId])
  @@index([serviceId])
  @@index([staffUserId])
  @@index([status])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// COACH SESSION & BOOKING SYSTEM
// ────────────────────────────────────────────────────────────────────────────

model CoachSession {
  id             String              @id @default(uuid())
  coachId        String              // Staff user ID
  organizationId String?
  playerId       String?             // Optional, for 1-on-1
  recurringSessionId String?         // Link to RecurringSession if generated from pattern
  sessionType    String              @default("1-on-1") // "1-on-1", "group", "match_play", "fitness"
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  timezone       String              @default("UTC")
  courtId        String?
  maxParticipants Int                @default(1)
  price          Float?
  status         String              @default("scheduled") // "scheduled", "confirmed", "in-progress", "completed", "cancelled", "no-show"
  cancellationReason String?
  cancelledAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  
  coach          Staff               @relation("CoachSessions", fields: [coachId], references: [userId], onDelete: Cascade)
  organization   Organization?       @relation("CoachSessions", fields: [organizationId], references: [id], onDelete: SetNull)
  player         Player?             @relation("CoachSessionsAsPlayer", fields: [playerId], references: [userId], onDelete: SetNull)
  court          Court?              @relation("CoachSessions", fields: [courtId], references: [id], onDelete: SetNull)
  recurringSource RecurringSession?  @relation("RecurringSource", fields: [recurringSessionId], references: [id], onDelete: SetNull)
  bookings       SessionBooking[]
  progressUpdates ProgressUpdate[]
  metricHistories MetricHistory[]
  sessionReport  SessionReport?
  earnings       CoachEarning[]

  @@index([coachId, startTime])
  @@index([organizationId, startTime])
  @@index([playerId, startTime])
  @@index([recurringSessionId])
  @@index([status])
  @@index([createdAt])
}

model SessionBooking {
  id             String              @id @default(uuid())
  sessionId      String
  playerId       String
  status         String              @default("pending") // "pending", "confirmed", "cancelled", "completed"
  attendanceStatus String?           @default("pending") // "pending", "attended", "absent", "late"
  notes          String?
  feedbackRating Float?              @default(0)
  feedbackText   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  completedAt    DateTime?
  
  session        CoachSession        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  player         Player              @relation("SessionBookings", fields: [playerId], references: [userId], onDelete: Cascade)
  
  @@unique([sessionId, playerId])
  @@index([sessionId])
  @@index([playerId])
  @@index([status])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// EARNINGS & WALLET SYSTEM
// ────────────────────────────────────────────────────────────────────────────

model CoachWallet {
  id             String              @id @default(uuid())
  coachId        String              @unique
  balance        Float               @default(0)
  currency       String              @default("USD")
  totalEarned    Float               @default(0)
  totalWithdrawn Float               @default(0)
  pendingBalance Float               @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  
  coach          Staff               @relation("CoachWallet", fields: [coachId], references: [userId], onDelete: Cascade)
  transactions   WalletTransaction[]
  
  @@index([coachId])
}

model WalletTransaction {
  id             String              @id @default(uuid())
  walletId       String
  type           String              // "credit", "debit", "withdrawal"
  amount         Float
  description    String
  reference      String?             // sessionId or payoutId
  balanceBefore  Float
  balanceAfter   Float
  platformFee    Float               @default(0)
  createdAt      DateTime            @default(now())
  
  wallet         CoachWallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  @@index([walletId, createdAt])
  @@index([type])
}

model CoachPayout {
  id             String              @id @default(uuid())
  coachId        String
  amount         Float
  status         String              @default("pending") // "pending", "processing", "completed", "failed"
  paymentMethod  String              // "bank_transfer", "mpesa", etc.
  bankDetails    String?
  transactionRef String?
  notes          String?
  requestedAt    DateTime            @default(now())
  processedAt    DateTime?
  completedAt    DateTime?
  
  coach          Staff               @relation("CoachPayouts", fields: [coachId], references: [userId], onDelete: Cascade)
  
  @@index([coachId])
  @@index([status])
  @@index([requestedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// PLAYER MANAGEMENT
// ────────────────────────────────────────────────────────────────────────────

model CoachPlayerRelationship {
  id             String              @id @default(uuid())
  coachId        String
  playerId       String
  status         String              @default("active") // "active", "inactive", "archived"
  joinedAt       DateTime            @default(now())
  lastSessionAt  DateTime?
  sessionsCount  Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  
  coach          Staff               @relation("CoachPlayers", fields: [coachId], references: [userId], onDelete: Cascade)
  player         Player              @relation("CoachPlayers", fields: [playerId], references: [userId], onDelete: Cascade)
  notes          CoachPlayerNote[]
  
  @@unique([coachId, playerId])
  @@index([coachId])
  @@index([playerId])
  @@index([status])
}

model CoachPlayerNote {
  id             String              @id @default(uuid())
  relationshipId String
  title          String
  content        String
  category       String?             // "performance", "injury", "progress", "general"
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  
  relationship   CoachPlayerRelationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  
  @@index([relationshipId])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// ANALYTICS & STATISTICS
// ────────────────────────────────────────────────────────────────────────────

model CoachStats {
  id             String              @id @default(uuid())
  coachId        String              @unique
  totalSessions  Int                 @default(0)
  completedSessions Int              @default(0)
  totalPlayers   Int                 @default(0)
  activePlayers  Int                 @default(0)
  totalRevenue   Float               @default(0)
  avgRating      Float               @default(0)
  ratingCount    Int                 @default(0)
  responseRate   Float               @default(0)
  cancellationRate Float             @default(0)
  updatedAt      DateTime            @updatedAt
  
  coach          Staff               @relation("CoachStats", fields: [coachId], references: [userId], onDelete: Cascade)
  
  @@index([coachId])
}

model CoachDailyStats {
  id             String              @id @default(uuid())
  coachId        String
  date           DateTime
  sessionsCount  Int                 @default(0)
  revenue        Float               @default(0)
  newPlayers     Int                 @default(0)
  createdAt      DateTime            @default(now())
  
  coach          Staff               @relation("CoachDailyStats", fields: [coachId], references: [userId], onDelete: Cascade)
  
  @@unique([coachId, date])
  @@index([coachId, date])
}

// ────────────────────────────────────────────────────────────────────────────
// REVIEWS & FEEDBACK EXTENSIONS
// ────────────────────────────────────────────────────────────────────────────

model CoachSessionReview {
  id             String              @id @default(uuid())
  coachId        String
  playerId       String
  sessionId      String
  rating         Float              // 1-5
  comment        String?
  isAnonymous    Boolean            @default(false)
  createdAt      DateTime           @default(now())
  
  coach          Staff              @relation("CoachSessionReviews", fields: [coachId], references: [userId], onDelete: Cascade)
  player         Player             @relation("CoachSessionReviews", fields: [playerId], references: [userId], onDelete: Cascade)
  
  @@unique([sessionId, playerId])
  @@index([coachId])
  @@index([playerId])
  @@index([createdAt])
}

model Activity {
  id             String              @id @default(uuid())
  coachId        String              // Staff user ID
  type           String              // 'session', 'tournament', 'restocking', 'player-reachout', 'email'
  date           String              // YYYY-MM-DD format
  startTime      String              // HH:MM format
  endTime        String              // HH:MM format
  title          String
  description    String?
  metadata       Json?               // Flexible storage for type-specific fields
  completed      Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  
  coach          Staff               @relation("Activities", fields: [coachId], references: [userId], onDelete: Cascade)
  
  @@index([coachId])
  @@index([date])
  @@index([type])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// TYPED TASK SYSTEM - Role-aware Workflow Engine
// ────────────────────────────────────────────────────────────────────────────

// FormField: Individual form field definition for task submissions
model FormField {
  id             String          @id @default(uuid())
  sectionId      String
  name           String          // e.g. "matchWinner", "score", "injuries"
  label          String          // Display label
  type           String          // text, textarea, number, date, select, checkbox, file
  required       Boolean         @default(true)
  placeholder    String?
  helpText       String?
  options        Json?           // For select/multi-select: [{label, value}, ...]
  validation     Json?           // {"min": 0, "max": 100, "pattern": "..."}
  position       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  section        FormSection     @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  @@index([sectionId])
}

// FormSection: Group of fields within a form
model FormSection {
  id             String          @id @default(uuid())
  templateId     String
  title          String
  description    String?
  position       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  template       TaskTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fields         FormField[]
  
  @@index([templateId])
}

// TaskTemplate: Admin-defined template for a type of work
model TaskTemplate {
  id             String          @id @default(uuid())
  organizationId String
  name           String          // e.g. "Manage Tournament", "Coach Training Plan"
  description    String?
  role           String          // REFEREE | COACH | ADMIN
  type           String          // e.g., TOURNAMENT_CONTROL, MATCH_OFFICIATION, TRAINING_PLAN, PLAYER_EVALUATION
  isFormBased    Boolean         @default(false) // false for event-driven (referee), true for form-driven (coach)
  
  // Form configuration for form-based tasks
  formSchema     Json?           // Backup full schema storage if needed
  
  // Context fields that are required when assigning
  contextFields  String[]        @default([]) // e.g., ["tournamentId", "matchId", "playerIds"]
  
  // Metadata
  instructions   String?         // Instructions for the person doing the task
  estimatedHours Float?
  successCriteria Json?          // Conditions for completion
  
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  organization   Organization    @relation("TaskTemplates", fields: [organizationId], references: [id], onDelete: Cascade)
  sections       FormSection[]
  tasks          Task[]
  
  @@index([organizationId])
  @@index([role])
  @@index([type])
}

// Task: Actual task instance assigned to a user
model Task {
  id             String          @id @default(uuid())
  templateId     String
  organizationId String
  assignedToId   String          // User ID (Staff for coaches, Referee for referees)
  assignedById   String          // Admin User ID
  
  // Task lifecycle
  status         String          @default("ASSIGNED") // ASSIGNED, ACCEPTED, IN_PROGRESS, COMPLETED, FAILED, CANCELLED
  statusHistory  Json            @default("[]") // [{status, timestamp, notes, ...}]
  
  // Context for this specific task
  context        Json            // {tournamentId, matchId, playerIds, etc}
  
  // Timeline
  dueDate        DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  
  // Feedback
  rejectionReason String?
  notes          String?
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  template       TaskTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  organization   Organization    @relation("OrganizationTasks", fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo     Staff           @relation("TaskAssignmentStaff", fields: [assignedToId], references: [userId], onDelete: Restrict)
  assignedBy     User            @relation("TaskAssignmentAdmin", fields: [assignedById], references: [id], onDelete: Restrict)
  submissions    TaskSubmission[]
  history        TaskHistory[]
  notificationLogs NotificationLog[] @relation("TaskNotifications")
  resourceRequests ResourceRequest[] @relation("TaskResources")
  
  @@index([templateId])
  @@index([organizationId])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
  @@index([dueDate])
  @@unique([id, organizationId])
}

// ResourceRequest: Referee requests for equipment/resources (VAR machine, ball crew, etc.)
model ResourceRequest {
  id             String          @id @default(uuid())
  taskId         String
  requestedByUserId String       // Referee who requested
  
  // Resource details
  resourceType   String          // "var_machine", "ball_crew", "net_repair", "lights", etc.
  quantity       Int             @default(1)
  description    String?         // Additional details
  
  // Status workflow
  status         String          @default("PENDING")  // PENDING, APPROVED, REJECTED, COMPLETED
  approvedByUserId String?       // Admin who approved
  approvalNotes  String?
  
  // Timeline
  requestedAt    DateTime        @default(now())
  approvedAt     DateTime?
  completedAt    DateTime?
  updatedAt      DateTime        @updatedAt
  
  task           Task            @relation("TaskResources", fields: [taskId], references: [id], onDelete: Cascade)
  requestedBy    User            @relation("ResourceRequests", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  approvedBy     User?           @relation("ResourceApprovals", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  
  @@index([taskId])
  @@index([requestedByUserId])
  @@index([status])
  @@index([requestedAt])
}

// TaskSubmission: Proof of completion (form data + generated PDF)
model TaskSubmission {
  id             String          @id @default(uuid())
  taskId         String
  submittedByUserId String       // User who submitted
  
  // Submission data
  formData       Json            // {fieldName: value, ...}
  
  // Generated proof
  pdfUrl         String?         // S3 or local storage URL
  pdfFileName    String?
  pdfGeneratedAt DateTime?
  
  // Review workflow
  reviewStatus   String          @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED, NEEDS_REVISION
  reviewedByUserId String?       // Admin who reviewed
  reviewedAt     DateTime?       // When reviewed
  reviewNotes    String?         // Admin feedback
  
  // Timestamps
  submittedAt    DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  task           Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  submittedBy    User            @relation("TaskSubmissions", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  reviewedBy     User?           @relation("TaskSubmissionReviews", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  
  @@index([taskId])
  @@index([submittedByUserId])
  @@index([reviewStatus])
  @@index([submittedAt])
}

// TaskHistory: Audit trail for task status changes
model TaskHistory {
  id             String          @id @default(uuid())
  taskId         String
  status         String          // Previous status or action
  action         String          // "ASSIGNED", "ACCEPTED", "STARTED", "COMPLETED", "REJECTED", "CANCELLED"
  changedByUserId String
  notes          String?
  metadata       Json?           // Additional context
  createdAt      DateTime        @default(now())
  
  task           Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy      User            @relation(fields: [changedByUserId], references: [id], onDelete: Cascade)
  
  @@index([taskId])
  @@index([action])
  @@index([createdAt])
}

// NotificationLog: Track email delivery status and retries for task assignments
model NotificationLog {
  id             String          @id @default(uuid())
  taskId         String
  recipientEmail String          // Player email to send notification to
  status         String          @default("PENDING")  // PENDING, SENT, FAILED, DELIVERED
  attemptCount   Int             @default(0)          // Number of send attempts
  maxAttempts    Int             @default(3)          // Maximum retry attempts (3 times before day of training)
  lastError      String?         // Error message from last failed attempt
  nextRetryAt    DateTime?       // When to retry next (with exponential backoff)
  sentAt         DateTime?       // When successfully sent
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  task           Task            @relation("TaskNotifications", fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([recipientEmail])
  @@index([status])
  @@index([nextRetryAt])
  @@index([createdAt])
}

// BugReport: User-submitted bug reports for app improvement
model BugReport {
  id          String      @id @default(uuid())
  title       String
  description String
  severity    String      @default("medium") // "low", "medium", "high", "critical"
  pageUrl     String
  userAgent   String
  userId      String
  status      String      @default("open") // "open", "in_progress", "resolved", "closed"
  timestamp   DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════════
// OPERATING MODEL ENTITIES (Session-Centric Architecture)
// ═══════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────
// PROGRESS TRACKING SYSTEM
// ─────────────────────────────────────────────────────────────

model PlayerMetric {
  id                  String      @id @default(uuid())
  playerId            String
  organizationId      String
  
  // Core Metrics (0-100 scale)
  serve               Int         @default(50)
  forehand            Int         @default(50)
  backhand            Int         @default(50)
  movement            Int         @default(50)
  stamina             Int         @default(50)
  strategy            Int         @default(50)
  mentalToughness     Int         @default(50)
  courtAwareness      Int         @default(50)
  
  // Metadata
  lastUpdated         DateTime    @updatedAt
  createdAt           DateTime    @default(now())
  
  // Relations
  player              Player      @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  historicalScores    MetricHistory[]
  
  @@unique([playerId, organizationId])
  @@index([playerId])
  @@index([organizationId])
}

model MetricHistory {
  id                  String      @id @default(uuid())
  metricId            String
  sessionId           String
  
  // Scores at this point in time
  serve               Int
  forehand            Int
  backhand            Int
  movement            Int
  stamina             Int
  strategy            Int
  mentalToughness     Int
  courtAwareness      Int
  
  // Deltas (change from previous)
  changes             Json        // { serve: +5, forehand: -2 }
  trend               String      // "up", "down", "stable"
  
  timestamp           DateTime    @default(now())
  
  // Relations
  metric              PlayerMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  session             CoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([metricId])
  @@index([sessionId])
  @@index([timestamp])
}

model ProgressUpdate {
  id                  String      @id @default(uuid())
  playerId            String
  coachId             String      // Who submitted the update
  sessionId           String
  
  // Coach submission
  ratingChanges       Json        // { serve: +5, forehand: -2, strategy: 0 }
  focusAreas          String[]    // ["forehand", "serve"]
  notes               String?
  
  // Calculated fields
  overallProgress     Int         // 0-100
  timestamp           DateTime    @default(now())
  
  // Relations
  session             CoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  coach               Staff        @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  
  @@index([playerId])
  @@index([coachId])
  @@index([sessionId])
  @@index([timestamp])
}

// ─────────────────────────────────────────────────────────────
// RECOMMENDATIONS ENGINE
// ─────────────────────────────────────────────────────────────

model Recommendation {
  id                  String      @id @default(uuid())
  organizationId      String
  targetId            String      // playerId, parentId, or coachId
  targetType          String      // "player" | "parent" | "coach"
  
  // Content
  title               String
  description         String
  priority            String      // "high" | "medium" | "low"
  category            String      // "training" | "match" | "enrollment" | "progress"
  
  // Trigger & Analysis
  triggeredBy         String      // "session_analysis" | "match_result" | "weekly_job"
  triggerData         Json?       // Data that triggered recommendation
  
  // Actions
  actionItems         String[]    // Specific next steps
  linkedSessionId     String?
  linkedMatchId       String?
  
  // Engagement
  acknowledged        Boolean     @default(false)
  acknowledgedAt      DateTime?
  status              String      @default("active") // "active" | "completed" | "dismissed"
  
  createdAt           DateTime    @default(now())
  validUntil          DateTime?   // Auto-expire
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([targetId])
  @@index([targetType])
  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// FINANCIAL SYSTEM (Org-Centric)
// ─────────────────────────────────────────────────────────────

model OrgRevenue {
  id                  String      @id @default(uuid())
  organizationId      String
  
  // Payment source
  paymentType         String      // "per_session" | "subscription" | "tournament"
  fromPlayerId        String?     // Player who paid (or their account)
  fromParentId        String?     // Parent who paid (via Guardian)
  
  // Amount
  amount              Decimal     @db.Decimal(10, 2)
  currency            String      @default("KES")
  status              String      @default("pending") // "pending" | "confirmed" | "reconciled"
  
  // References
  sessionIds          String[]    // Sessions this pays for
  subscriptionId      String?
  invoiceId           String?
  
  // Payment method
  mpesaTransactionId  String?
  paymentMethod       String      // "mpesa" | "bank" | "cash" | "card"
  
  createdAt           DateTime    @default(now())
  recordedAt          DateTime?
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([fromPlayerId])
  @@index([fromParentId])
  @@index([status])
  @@index([createdAt])
}

model CoachEarning {
  id                  String      @id @default(uuid())
  sessionId           String      @unique
  coachId             String
  organizationId      String
  
  // Calculation
  sessionPrice        Decimal     @db.Decimal(10, 2)
  coachPercentage     Decimal     @default(0.60) @db.Decimal(3, 2) // 60% default
  amount              Decimal     @db.Decimal(10, 2)
  
  // Status
  status              String      @default("pending") // "pending" | "approved" | "paid"
  approvedAt          DateTime?
  paidAt              DateTime?
  payoutCycleId       String?
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  session             CoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  staff               Staff       @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  
  @@index([coachId])
  @@index([status])
  @@index([organizationId])
}

model CoachPayoutCycle {
  id                  String      @id @default(uuid())
  organizationId      String
  cycleNumber         String      // "2026-04-W1" or "2026-04"
  cycleType           String      // "weekly" | "monthly"
  
  // Details
  payoutDate          DateTime
  totalAmount         Decimal     @db.Decimal(10, 2)
  earningIds          String[]    // CoachEarning IDs included
  
  // Payment
  paymentMethod       String      // "mpesa" | "bank"
  transactionId       String?
  status              String      @default("pending") // "pending" | "approved" | "sent" | "confirmed"
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([payoutDate])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// SCHEDULING SYSTEM
// ─────────────────────────────────────────────────────────────

model CoachAvailability {
  id                  String      @id @default(uuid())
  coachId             String
  organizationId      String
  
  // Recurrence
  dayOfWeek           Int         // 0=Sunday, 6=Saturday
  startTime           String      // "14:00"
  endTime             String      // "18:00"
  
  // Constraints
  maxSessionsPerDay   Int         @default(6)
  sessionDuration     Int         @default(60) // minutes
  bufferMinutes       Int         @default(0)
  
  // Exceptions
  isRecurring         Boolean     @default(true)
  recurringUntil      DateTime?
  blackoutDates       DateTime[]  // Days not available
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  staff               Staff       @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([coachId])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────
// COMMUNICATION SYSTEM
// ─────────────────────────────────────────────────────────────

model Message {
  id                  String      @id @default(uuid())
  fromId              String
  toId                String
  organizationId      String
  
  // Content
  type                String      @default("text") // "text" | "voice" | "file"
  content             String
  attachmentUrl       String?
  
  // Context
  sessionId           String?
  
  // Status
  read                Boolean     @default(false)
  readAt              DateTime?
  
  createdAt           DateTime    @default(now())
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([fromId])
  @@index([toId])
  @@index([organizationId])
  @@index([createdAt])
}

model Announcement {
  id                  String      @id @default(uuid())
  organizationId      String
  authorId            String
  
  title               String
  content             String
  audience            String      // "coaches" | "players" | "parents" | "all"
  
  postedAt            DateTime    @default(now())
  expiresAt           DateTime?
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([audience])
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION SYSTEM
// ─────────────────────────────────────────────────────────────

model Notification {
  id                  String      @id @default(uuid())
  organizationId      String
  targetId            String      // User receiving notification
  targetType          String      // "coach" | "player" | "parent"
  
  // Event
  eventType           String      // "session_booked", "session_reminder", "session_completed", etc.
  eventId             String?     // Reference to related entity
  
  // Content
  title               String
  body                String
  action              String?     // "view_report", "book_session"
  actionUrl           String?
  
  // Delivery
  deliveryChannels    String[]    // ["sms", "push", "email"]
  sentAt              DateTime?
  readAt              DateTime?
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([targetId])
  @@index([organizationId])
  @@index([eventType])
  @@index([sentAt])
}

// ─────────────────────────────────────────────────────────────
// SESSION REPORTING
// ─────────────────────────────────────────────────────────────

model SessionReport {
  id                  String      @id @default(uuid())
  sessionId           String      @unique
  
  // Coach submission
  rating              Int         // Overall session rating (0-100)
  duration            Int         // Actual duration in minutes
  playerAttendance    Json        // { playerId: attended (bool) }
  
  // Content
  whatWasWorked       String[]    // Topics covered
  focusAreasNext      String[]    // Next session focus
  coachNotes          String?
  
  // Data collection
  submittedAt         DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  session             CoachSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  @@index([sessionId])
}

// ─────────────────────────────────────────────────────────────
// MULTI-LAYER REPORTING SYSTEM
// ─────────────────────────────────────────────────────────────

model PlayerReport {
  id                  String      @id @default(uuid())
  playerId            String
  organizationId      String
  
  // Report period
  reportDate          DateTime    @default(now())
  periodStart         DateTime
  periodEnd           DateTime
  
  // Metrics snapshot
  metricsSnapshot     Json        // Current metric values
  improvementScore    Int         @default(0) // 0-100
  
  // Analysis
  strengths           String[]    // Top 3 areas
  weaknesses          String[]    // Bottom 3 areas
  coachNotes          String?
  
  // Recommendations
  focusAreas          String[]
  recommendedNextSteps String[]
  
  // Meta
  generatedAt         DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  player              Player      @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([playerId])
  @@index([organizationId])
  @@index([reportDate])
}

model ParentReport {
  id                  String      @id @default(uuid())
  parentId            String
  childId             String
  organizationId      String
  
  // Child info
  childName           String
  
  // Summary (simplified for parents)
  improvementSummary  String      // Headline improvement
  sessionSummary      String      // Last 4 weeks summary
  
  // Key achievements
  achievements        String[]
  
  // Next steps
  recommendations     String[]
  
  // Financial
  sessionsEnrolled    Int
  totalPaid           Decimal     @db.Decimal(10, 2)
  nextPaymentDue      DateTime?
  
  // Meta
  generatedAt         DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([parentId])
  @@index([childId])
  @@index([organizationId])
  @@index([generatedAt])
}

model CoachReport {
  id                  String      @id @default(uuid())
  coachId             String
  organizationId      String
  
  // Time period
  periodStart         DateTime
  periodEnd           DateTime
  
  // Stats
  playersManaged      Int         @default(0)
  sessionsCompleted   Int         @default(0)
  sessionsScheduled   Int         @default(0)
  completionRate      Float       @default(0) // 0-100
  
  // Performance
  avgPlayerRating     Float       @default(0) // 0-5 stars
  playersImproving    Int         @default(0)
  playersStagnating   Int         @default(0)
  
  // Earnings
  earningsThisPeriod  Decimal     @db.Decimal(10, 2) @default(0)
  pendingEarnings     Decimal     @db.Decimal(10, 2) @default(0)
  payoutSchedule      String?
  
  // Feedback
  playerFeedback      String[]    // Recent reviews
  
  // Meta
  generatedAt         DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  staff               Staff       @relation(fields: [coachId], references: [userId], onDelete: Cascade)
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([coachId])
  @@index([organizationId])
  @@index([periodStart])
}

model OrgAnalytics {
  id                  String      @id @default(uuid())
  organizationId      String      @unique
  
  // Time period
  date                DateTime    @default(now()) @updatedAt
  
  // Revenue
  totalRevenue        Decimal     @db.Decimal(10, 2) @default(0)
  revenueByType       Json        // { per_session: X, subscription: Y, tournament: Z }
  
  // Players
  activePlayersCount  Int         @default(0)
  newPlayersCount     Int         @default(0)
  retentionRate       Float       @default(0) // 0-100
  churnedPlayersCount Int         @default(0)
  
  // Coaches
  activeCoachesCount  Int         @default(0)
  totalCoachEarnings  Decimal     @db.Decimal(10, 2) @default(0)
  avgCoachRating      Float       @default(0) // 0-5 stars
  
  // Sessions
  sessionCompletionRate Float     @default(0) // 0-100
  avgSessionRating    Float       @default(0) // 0-5 stars
  sessionsByType      Json        // { "1-on-1": X, "group": Y }
  
  // Courts
  courtUtilization    Float       @default(0) // 0-100
  totalBookings       Int         @default(0)
  peakHours           String[]    // Peak booking times
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Invoice {
  id                  String      @id @default(uuid())
  organizationId      String
  playerId            String
  
  // Details
  invoiceNumber       String      @unique
  issueDate           DateTime    @default(now())
  dueDate             DateTime
  
  // Items
  lineItems           Json        // Array of { description, quantity, unitPrice, amount }
  
  // Totals
  totalAmount         Decimal     @db.Decimal(10, 2)
  paidAmount          Decimal     @db.Decimal(10, 2) @default(0)
  
  // Status
  status              String      @default("draft") // "draft" | "issued" | "paid" | "overdue"
  
  // Payment
  paymentMethod       String?
  paidAt              DateTime?
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  player              Player      @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([playerId])
  @@index([status])
  @@index([dueDate])
}

model PaymentMethod {
  id                  String      @id @default(uuid())
  organizationId      String
  
  // Type
  type                String      // "mpesa" | "bank_transfer" | "card" | "cash"
  name                String      // Display name
  
  // M-Pesa
  mpesaBusinessCode   String?
  mpesaAccountCode    String?
  
  // Bank
  accountName         String?
  accountNumber       String?
  bankName            String?
  swiftCode           String?
  
  // Card processing (Stripe, etc.)
  stripeAccountId     String?
  
  // Active
  isActive            Boolean     @default(true)
  isDefault           Boolean     @default(false)
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([type])
}

model Subscription {
  id                  String      @id @default(uuid())
  organizationId      String
  playerId            String
  
  // Details
  type                String      // "monthly" | "quarterly" | "yearly"
  sessionsPerPeriod   Int
  pricePerPeriod      Decimal     @db.Decimal(10, 2)
  
  // Status
  status              String      @default("active") // "active" | "paused" | "cancelled"
  
  // Dates
  startDate           DateTime
  endDate             DateTime?
  nextBillingDate     DateTime
  
  // Auto-renewal
  autoRenew           Boolean     @default(true)
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  player              Player      @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([playerId])
  @@index([status])
  @@index([nextBillingDate])
}

model NotificationTrigger {
  id                  String      @id @default(uuid())
  organizationId      String
  
  // Event
  eventType           String      // "session.completed", "progress.updated", etc.
  triggerCondition    Json?       // Conditions for triggering (optional)
  
  // Recipients
  notifyTo            String[]    // ["player", "parent", "coach", "admin"]
  
  // Channels
  channels            String[]    // ["sms", "push", "email"]
  
  // Templates
  messageTemplate     String
  titleTemplate       String
  
  // Control
  isActive            Boolean     @default(true)
  retryCount          Int         @default(3)
  retryDelayMinutes   Int         @default(5)
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  
  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([eventType])
  @@index([isActive])
}


// ─────────────────────────────────────────────────────────────────────
// EVENT LOG & DOMAIN EVENT TRACKING
// ─────────────────────────────────────────────────────────────────────

model EventLog {
  id                String      @id
  type              String      // SESSION_COMPLETED, INVOICE_CREATED, etc.
  aggregateId       String      // Which entity changed (sessionId, playerId, etc.)
  aggregateType     String      // Entity type (Session, Player, Organization, etc.)
  organizationId    String
  
  occurredAt        DateTime    // When it actually happened
  publishedAt       DateTime    // When published to event stream
  processedAt       DateTime?   // When last processed
  
  status            String      @default("published") // published | processed | failed
  payload           Json        // Full event data for handlers
  metadata          Json?       // userId, source, correlationId, etc.
  
  // Processing audit trail
  processingRecords Json?       // [{handlerName, status, error, timestamp}]
  
  createdAt         DateTime    @default(now())
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([type])
  @@index([aggregateId])
  @@index([organizationId])
  @@index([publishedAt])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────
// INVOICE & BILLING LAYER
// ─────────────────────────────────────────────────────────────────────

model InvoiceModel {
  id                String      @id @default(uuid())
  organizationId    String
  playerId          String
  parentId          String?     // Parent who pays
  
  // Invoice metadata
  invoiceNumber     String      @unique // "INV-2026-001"
  issueDate         DateTime    @default(now())
  dueDate           DateTime
  
  // Billing breakdown
  lineItems         Json        // [{description, sessionId, amount, quantity, date}]
  totalAmount       Decimal     @db.Decimal(12, 2)
  paidAmount        Decimal     @db.Decimal(12, 2) @default(0)
  
  // Status workflow
  status            String      @default("draft") // draft | issued | paid | partial | overdue | failed
  
  // Payment tracking
  paymentMethod     String?     // mpesa | bank_transfer | card
  paidAt            DateTime?
  
  // Dispute/adjustment
  notes             String?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  organization      Organization @relation("InvoiceModels", fields: [organizationId], references: [id], onDelete: Cascade)
  player            Player       @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  parentUser        User?        @relation("InvoiceParent", fields: [parentId], references: [id], onDelete: SetNull)
  
  @@unique([invoiceNumber, organizationId])
  @@index([organizationId])
  @@index([playerId])
  @@index([status])
  @@index([dueDate])
}

// ─────────────────────────────────────────────────────────────────────
// LEDGER SYSTEM (Source of truth for financial reconciliation)
// ─────────────────────────────────────────────────────────────────────

model LedgerEntry {
  id                String      @id @default(uuid())
  organizationId    String
  
  // Entry classification
  type              String      // credit | debit
  amount            Decimal     @db.Decimal(12, 2)
  currency          String      @default("USD")
  
  // Source tracking
  sourceType        String      // session | payout | refund | adjustment | subscription
  sourceId          String?     // Reference to source entity
  
  // Accounts
  debitAccount      String?     // coach_wallet, parent_receivable, etc.
  creditAccount     String?     // revenue, coach_earned, etc.
  
  // Metadata
  description       String
  referenceId       String?     // Invoice, Payout, Session, etc.
  
  createdAt         DateTime    @default(now())
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([sourceType])
  @@index([createdAt])
  @@index([referenceId])
}

// ─────────────────────────────────────────────────────────────────────
// PAYMENT RECOVERY & AUDIT
// ─────────────────────────────────────────────────────────────────────

model PaymentTransaction {
  id                String      @id @default(uuid())
  organizationId    String
  
  // Amount details
  amount            Decimal     @db.Decimal(12, 2)
  currency          String      @default("USD")
  
  // Gateway details
  gateway           String      // stripe | mpesa | bank_transfer | paypal
  transactionId     String?     // External transaction ID
  idempotencyKey    String      // Prevent duplicate charges
  
  // Status tracking
  status            String      @default("pending") // pending | processing | completed | failed | refunded
  error             String?
  
  // Timestamps
  initiatedAt       DateTime    @default(now())
  completedAt       DateTime?
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@unique([idempotencyKey])
  @@index([organizationId])
  @@index([status])
  @@index([gateway])
}

// ─────────────────────────────────────────────────────────────────────
// PROGRESS WEIGHTING (Normalization for fair scoring)
// ─────────────────────────────────────────────────────────────────────

model MetricWeight {
  id                String      @id @default(uuid())
  organizationId    String
  
  // Metric definition
  metricName        String      // "serve_accuracy", "stamina", "strategy", etc.
  playerLevel       String      // beginner | intermediate | advanced | elite
  
  // Weighting (0-1, where 1 = 100%)
  weight            Float       @default(1.0)
  
  // When this weight is valid
  activeFrom        DateTime    @default(now())
  activeTo          DateTime?
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@unique([organizationId, metricName, playerLevel])
  @@index([organizationId])
}

// ─────────────────────────────────────────────────────────────────────
// RECOMMENDATION GUARDRAILS
// ─────────────────────────────────────────────────────────────────────

model RecommendationConfig {
  id                String      @id @default(uuid())
  organizationId    String      @unique
  
  // Guardrails
  maxActivePerPlayer Int        @default(3)
  maxPerWeek        Int         @default(2)
  confidenceThreshold Float     @default(0.7) // 0-1 scale
  
  // Audience
  showLowConfidence  Boolean     @default(false) // Only internal?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────
// RECURRING SESSIONS (For scalable scheduling)
// ─────────────────────────────────────────────────────────────────────

model RecurringSession {
  id                String      @id @default(uuid())
  organizationId    String
  coachId           String
  
  // Pattern definition
  title             String
  description       String?
  pattern           String      // weekly | biweekly | monthly | custom
  daysOfWeek        Int[]       // [1,3,5] = Mon, Wed, Fri
  
  // Time
  startTime         DateTime    // First session start
  endTime           DateTime    // First session end (to calculate duration)
  timezone          String      @default("UTC")
  
  // Duration
  startDate         DateTime    // Pattern begins
  endDate           DateTime?   // Pattern ends (null = ongoing)
  
  // Limits
  maxParticipants   Int         @default(1)
  price             Float?
  
  // State
  isActive          Boolean     @default(true)
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  organization      Organization @relation("RecurringSessions", fields: [organizationId], references: [id], onDelete: Cascade)
  coach             Staff        @relation("RecurringCoachSessions", fields: [coachId], references: [userId], onDelete: Cascade)
  generatedSessions CoachSession[] @relation("RecurringSource")
  
  @@index([organizationId])
  @@index([coachId])
  @@index([startDate, endDate])
}

// ─────────────────────────────────────────────────────────────────────
// PARENT-CHILD OWNERSHIP TRANSFER
// ─────────────────────────────────────────────────────────────────────

model OwnershipTransfer {
  id                String      @id @default(uuid())
  organizationId    String
  playerId          String
  parentId          String
  
  // Transfer state
  status            String      @default("dependent") // dependent | transitioning | independent
  
  // Transition details
  transferDate      DateTime?   // When autonomy begins
  reason            String?     // age_of_majority | player_request | legal_order
  
  // Audit
  initiatedBy       String?     // Admin or system
  approvedAt        DateTime?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  player            Player       @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  parentUser        User         @relation("OwnershipTransferParent", fields: [parentId], references: [id], onDelete: Cascade)
  
  @@unique([playerId, parentId])
  @@index([organizationId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────
// NOTIFICATION RELIABILITY LOG
// ─────────────────────────────────────────────────────────────────────

model NotificationLogModel {
  id                String      @id @default(uuid())
  organizationId    String
  
  // What was sent
  channel           String      // email | sms | push
  template          String      // welcome_email, otp_sms, etc.
  recipient         String      // email or phone
  
  // Processing
  status            String      @default("pending") // pending | sent | failed | retrying
  attempts          Int         @default(0)
  maxAttempts       Int         @default(3)
  
  // Tracking
  eventId           String?     // EventLog.id that triggered this
  correlationId     String?     // Group related notifications
  
  // Error handling
  lastError         String?
  nextRetryAt       DateTime?
  
  sentAt            DateTime?
  failedAt          DateTime?
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([status])
  @@index([channel])
  @@index([nextRetryAt])
  @@index([eventId])
}

// ─────────────────────────────────────────────────────────────────────
// PRECOMPUTED ANALYTICS (Snapshot tables for fast reporting)
// ─────────────────────────────────────────────────────────────────────

model DailyPlayerStats {
  id                String      @id @default(uuid())
  organizationId    String
  playerId          String
  date              DateTime    // UTC date
  
  // Session activity
  sessionsAttended  Int         @default(0)
  sessionsMissed    Int         @default(0)
  
  // Performance
  avgRating         Float?
  metricScores      Json?       // Snapshot of that day's metrics
  
  // Milestones
  milestonesReached String[]    @default([])
  
  createdAt         DateTime    @default(now())
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  player            Player       @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  
  @@unique([organizationId, playerId, date])
  @@index([organizationId])
  @@index([date])
}

model CoachPerformanceSummary {
  id                String      @id @default(uuid())
  organizationId    String
  coachId           String
  period            String      // "2026-04" or "2026-W1"
  
  // Workload
  sessionsCompleted Int         @default(0)
  playersManaged    Int         @default(0)
  avgSessionRating  Float?
  
  // Earnings
  totalEarned       Decimal     @db.Decimal(12, 2) @default(0)
  pendingPayout     Decimal     @db.Decimal(12, 2) @default(0)
  
  createdAt         DateTime    @default(now())
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  coach             Staff        @relation("CoachPerformanceSummaries", fields: [coachId], references: [userId], onDelete: Cascade)
  
  @@unique([organizationId, coachId, period])
  @@index([organizationId])
  @@index([period])
}

model OrgMetricsSnapshot {
  id                String      @id @default(uuid())
  organizationId    String      @unique
  
  // Revenue
  totalRevenue      Decimal     @db.Decimal(12, 2)
  monthlyRecurring  Decimal     @db.Decimal(12, 2)
  
  // Players
  activePlayersCount Int
  newThisMonth      Int
  churnedThisMonth  Int
  
  // Coaches
  activeCoachesCount Int
  avgCoachRating    Float?
  totalCoachEarnings Decimal @db.Decimal(12, 2)
  
  // Health
  completionRate    Float       // 0-1
  avgSessionRating  Float?
  
  updatedAt         DateTime    @updatedAt
  
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
