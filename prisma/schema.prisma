generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// base table for all user types with shared attributes
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  firstName    String
  lastName     String
  photo        String? // profile picture URL
  gender       String? // Male/Female/Other
  dateOfBirth  DateTime?
  nationality  String?
  bio          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations to various specialized profiles
  player   Player?
  referee  Referee?
  staff    Staff?
  spectator Spectator?
}

model Player {
  // one-to-one with User for common fields
  userId         String   @id
  user           User     @relation(fields: [userId], references: [id])

  // Statistics
  matchesPlayed   Int @default(0)
  matchesWon      Int @default(0)
  matchesLost     Int @default(0)

  // Relations
  playerBadges    PlayerBadge[]
  matchesA        Match[]         @relation("PlayerA")
  matchesB        Match[]         @relation("PlayerB")
  ballCrewMatches MatchBallCrew[]
  chatMessages    ChatMessage[]
  chatRooms       ChatParticipant[]
  clubMembers     ClubMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Match Match[]
  inventoryItems InventoryItem[]
  staffMembers Staff[]
  attendance Attendance[]
  performancePoints PerformancePoint[]
  isClub      Boolean   @default(false)
  // Organization membership
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  @@index([organizationId])
}

model InventoryItem {
  id        String   @id @default(uuid())
  name      String
  count     Int      @default(0)
  condition String?
  club      Player?  @relation(fields: [clubId], references: [userId])
  clubId    String?
  // Optional organization ownership
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  updatedAt DateTime @updatedAt
}

model Referee {
  userId        String   @id
  user          User     @relation(fields: [userId], references: [id])

  // Statistics
  matchesRefereed Int @default(0)
  ballCrewMatches Int @default(0)
  experience     String? // years of experience
  certifications String[] @default([]) // referee certifications

  // Relations
  refereedMatches Match[]        @relation("Referee")
  ballCrewReferees MatchBallCrew[] @relation("BallCrewReferee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  userId                String   @id
  user                  User     @relation(fields: [userId], references: [id])

  // core contact info beyond User
  contact               String? // Contact information (email or phone preferred for display)

  // Core coaching info
  role                  String // Head Coach, Assistant Coach, Fitness Coach, Junior Coach
  yearsOfExperience     Int? @default(0)
  expertise             String? // primary specialization
  
  // Qualifications & Credibility
  coachingLevel         String? // Beginner, Intermediate, Advanced, Professional
  formerPlayerBackground String? // bio about playing career
  certifications        Certification[]
  specializations       Specialization[]
  
  // Capabilities
  playerAgeGroups       String[] @default([]) // Kids, Teens, Adults
  skillLevelsTrained    String[] @default([]) // Beginner, Intermediate, Advanced, Professional
  trainingTypes         String[] @default([]) // Private sessions, Group sessions, Clinics, Online coaching
  languagesSpoken       String[] @default([])
  
  // Availability & Scheduling
  availability          Availability[]
  sessionDurations      Int[] @default([30, 60, 90]) // in minutes
  maxStudentsPerSession Int? @default(1)
  courtLocations        String[] @default([])
  
  // Pricing & Monetization
  pricing               CoachPricing?
  
  // Bio & Content
  bio                   String? // short bio
  coachingPhilosophy    String? // coaching philosophy
  achievements          String? // notable achievements
  introVideoUrl         String? // optional intro video
  
  // Reputation & Social Proof
  reviews               CoachReview[]
  studentCount          Int @default(0) // denormalized count
  
  // Admin/System
  isVerified            Boolean @default(false)
  isActive              Boolean @default(true)
  isDeleted             Boolean @default(false)
  ownerId               String? // User/Player who owns this coach profile
  auditLogs             AuditLog[]
  
  // Relations
  employedBy            Player?  @relation(fields: [employedById], references: [userId])
  employedById          String?
  // Organization employment
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Spectators represent users who attend matches/events but do not participate
model Spectator {
  userId String @id
  user   User   @relation(fields: [userId], references: [id])
  // additional spectator-specific fields could go here
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Organization model for clubs/teams
model Organization {
  // optionally link to a user account representing the organization
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String?      @unique
  description String?
  address     String?
  city        String?
  country     String?
  phone       String?
  email       String?
  logo        String?      // URL to logo image
  primaryColor String?     // e.g. '#0ea5e9' or 'blue-500'
  createdBy   String?      // Player ID who created the organization
  
  // Club rating & reputation
  rating      Float?       @default(0) // 0-5 stars
  ratingCount Int          @default(0)
  verifiedBadge Boolean    @default(false)
  activityScore Int        @default(0) // 0-100
  playerDevScore Int       @default(0) // 0-100 (player development)
  tournamentEngScore Int   @default(0) // 0-100 (tournament engagement)

  // Relations
  players     Player[]
  staff       Staff[]
  inventory   InventoryItem[]
  courts      Court[]
  bookings    CourtBooking[]
  members     ClubMember[]
  rankings    PlayerRanking[]
  events      ClubEvent[]
  announcements ClubAnnouncement[]
  finances    ClubFinance[]
  roles       OrganizationRole[]
  permissions RolePermission[]
  tournamentBrackets TournamentBracket[]
  matches     TournamentMatch[]
  orgBadges   OrganizationBadge[]
  ratings     ClubRating[]
  membershipTiers MembershipTier[] @relation("membershipTiers")
  challenges  RankingChallenge[] @relation("challenges")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Certifications
model Certification {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
  name      String   // ITF, ATP, WTA, National federation, etc.
  issuer    String? // Organization that issued it
  issuedAt  DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  
  @@unique([staffId, name])
}

// Specializations
model Specialization {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
  name      String   // Singles, Doubles, Juniors, High-performance, Fitness, Injury recovery
  level     String? // Beginner, Intermediate, Advanced
  yearsOfFocus Int? // years focused on this specialization
  createdAt DateTime @default(now())
  
  @@unique([staffId, name])
}

// Weekly Availability
model Availability {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
  dayOfWeek Int      // 0=Monday, 1=Tuesday, ..., 6=Sunday
  startTime String   // HH:MM format (24-hour)
  endTime   String   // HH:MM format (24-hour)
  createdAt DateTime @default(now())
  
  @@unique([staffId, dayOfWeek, startTime])
}

// Pricing
model CoachPricing {
  id                 String   @id @default(uuid())
  staffId            String   @unique
  staff              Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
  pricePerSession    Float    // base price
  currency           String   @default("USD")
  
  // Package pricing
  package3Sessions   Float?   // 3-session package price
  package10Sessions  Float?   // 10-session package price
  
  // Discounts
  juniorDiscount     Float? @default(0) // percentage discount
  groupSessionDiscount Float? @default(0) // percentage discount
  
  // Commission (if marketplace)
  commissionRate     Float? @default(0) // percentage
  
  paymentMethods     String[] @default(["credit_card", "bank_transfer"]) // supported payment methods
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Reviews & Ratings
model CoachReview {
  id           String   @id @default(uuid())
  staffId      String
  staff        Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
  playerId     String   // student who reviewed
  rating       Float    // 1-5 rating
  reviewText   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@unique([staffId, playerId])
}

// Audit Logs for admin/system changes
model AuditLog {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [userId], onDelete: Cascade)
  action    String   // Created, Updated, Verified, Deleted, etc.
  field     String?  // which field was changed
  oldValue  String?  // previous value
  newValue  String?  // new value
  performedBy String? // User who performed action
  createdAt DateTime @default(now())
}


model Match {
  id        String          @id @default(uuid())
  round     Int
  playerA   Player          @relation("PlayerA", fields: [playerAId], references: [userId])
  playerAId String
  playerB   Player          @relation("PlayerB", fields: [playerBId], references: [userId])
  playerBId String
  referee   Referee?        @relation("Referee", fields: [refereeId], references: [userId])
  refereeId String?
  ballCrew  MatchBallCrew[]
  winner    Player?         @relation(fields: [winnerId], references: [userId])
  winnerId  String?
  group     String?
  score     String?
  createdAt DateTime        @default(now())
}

model MatchBallCrew {
  id       String  @id @default(uuid())
  match    Match   @relation(fields: [matchId], references: [id])
  matchId  String
  player   Player  @relation(fields: [playerId], references: [userId])
  playerId String
  ballCrewReferee Referee? @relation("BallCrewReferee", fields: [refereeId], references: [userId])
  refereeId String?
}

model Badge {
  id           String        @id @default(uuid())
  name         String
  description  String
  category     String // e.g. "Wins", "Referee", "Participation"
  icon         String? // optional icon/image URL
  playerBadges PlayerBadge[]
}

model PlayerBadge {
  id       String   @id @default(uuid())
  player   Player   @relation(fields: [playerId], references: [userId])
  playerId String
  badge    Badge    @relation(fields: [badgeId], references: [id])
  badgeId  String
  earnedAt DateTime @default(now())
}

// Analytics models: attendance records and per-player performance points
model Attendance {
  id       String   @id @default(uuid())
  player   Player   @relation(fields: [playerId], references: [userId])
  playerId String
  date     DateTime
  present  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PerformancePoint {
  id       String   @id @default(uuid())
  player   Player   @relation(fields: [playerId], references: [userId])
  playerId String
  date     DateTime
  rating   Float
  points   Int
  createdAt DateTime @default(now())
}

model TennisRule {
  id        String   @id @default(uuid())
  category  String   // Scoring, Basic Rules, Court & Equipment, Key Violations
  label     String   // display label
  value     String?  // description or value
  createdAt DateTime @default(now())

  @@unique([category, label])
}

// Chat Models
model ChatRoom {
  id           String   @id @default(uuid())
  name         String
  description  String?
  isPrivate    Boolean  @default(false)
  createdBy    String   // Player ID who created the room
  messages     ChatMessage[]
  participants ChatParticipant[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  playerId  String   // Player who sent the message
  player    Player   @relation(fields: [playerId], references: [userId])
  content   String
  createdAt DateTime @default(now())
  // delivery/read receipt timestamps used for UI ticks
  deliveredAt DateTime? // set when message has been delivered to the room
  readAt      DateTime? // set when at least one recipient has opened/seen the message

  @@index([roomId, createdAt])
}

model ChatParticipant {
  id        String   @id @default(uuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [userId])
  isOnline  Boolean  @default(false)
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([roomId, playerId])
}

// ==================== COURT MANAGEMENT ====================

model Court {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  name            String   // Court 1, Court 2, etc.
  courtNumber     Int
  surface         String   // Hard, Clay, Grass, etc.
  indoorOutdoor   String   @default("outdoor") // indoor/outdoor
  lights          Boolean  @default(false)
  
  status          String   @default("available") // available, booked, maintenance, closed
  maintenedUntil  DateTime? // when maintenance ends
  
  bookings        CourtBooking[]
  tournamentMatches TournamentMatch[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, courtNumber])
}

model CourtBooking {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  court           Court    @relation(fields: [courtId], references: [id], onDelete: Cascade)
  courtId         String
  
  member          ClubMember? @relation(fields: [memberId], references: [id])
  memberId        String?
  playerName      String? // for guests
  
  startTime       DateTime
  endTime         DateTime
  
  bookingType     String   @default("regular") // regular, tournament, maintenance, guest
  guestCount      Int      @default(1)
  
  status          String   @default("confirmed") // confirmed, cancelled, no-show, completed
  price           Float?
  isPeak          Boolean  @default(false) // peak hours pricing
  
  cancellationReason String?
  cancelledAt     DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== MEMBERSHIP MANAGEMENT ====================

model MembershipTier {
  id              String   @id @default(uuid())
  organization    Organization? @relation("membershipTiers", fields: [organizationId], references: [id])
  organizationId  String?
  
  name            String   @unique // Gold, Silver, Junior, etc.
  description     String?
  
  monthlyPrice    Float
  benefitsJson    String? // JSON string of benefits
  
  courtHoursPerMonth Int?
  maxConcurrentBookings Int? @default(3)
  discountPercentage Float? @default(0)
  
  clubMembers     ClubMember[] @relation("membershipTier")
  
  createdAt       DateTime @default(now())
}

model ClubMember {
  // future spectator or additional user types could reference here
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  player          Player   @relation(fields: [playerId], references: [userId], onDelete: Cascade)
  playerId        String
  
  membershipTier  MembershipTier? @relation("membershipTier", fields: [tierId], references: [id])
  tierId          String?
  
  joinDate        DateTime @default(now())
  expiryDate      DateTime?
  autoRenew       Boolean  @default(true)
  
  paymentStatus   String   @default("active") // active, suspended, expired, overdue
  outstandingBalance Float @default(0)
  
  attendanceCount Int      @default(0) // this month or overall
  lastAttendance  DateTime?
  
  role            String   @default("member") // member, coach, admin, finance_officer, guest
  
  suspensionReason String?
  suspendedUntil  DateTime?
  
  bookings        CourtBooking[]
  eventRegistrations EventRegistration[]
  waitlistItems   EventWaitlist[]
  rankings        PlayerRanking[]
  challengesAsChallenger RankingChallenge[] @relation("challenger")
  challengesAsOpponent RankingChallenge[] @relation("opponent")
  tournamentMatchesA TournamentMatch[] @relation("matchPlayerA")
  tournamentMatchesB TournamentMatch[] @relation("matchPlayerB")
  financeTransactions FinanceTransaction[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, playerId])
}

// ==================== RANKING SYSTEM ====================

model PlayerRanking {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  member          ClubMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId        String
  
  weekNumber      Int // ISO week number
  year            Int
  
  currentRank     Int      // 1, 2, 3...
  previousRank    Int?
  ratingPoints    Int      // tennis rating points
  
  matchesWon      Int      @default(0)
  matchesLost     Int      @default(0)
  winRate         Float    @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, memberId, weekNumber, year])
}

model RankingChallenge {
  id              String   @id @default(uuid())
  organization    Organization? @relation("challenges", fields: [organizationId], references: [id])
  organizationId  String?
  
  challenger      ClubMember @relation("challenger", fields: [challengerId], references: [id])
  challengerId    String
  
  opponent        ClubMember @relation("opponent", fields: [opponentId], references: [id])
  opponentId      String
  
  challengeDate   DateTime
  matchDate       DateTime?
  
  status          String   @default("pending") // pending, accepted, rejected, completed
  winnerId        String? // ClubMember ID
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== EVENTS & TOURNAMENTS ====================

model ClubEvent {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  name            String
  description     String?
  eventType       String   // tournament, clinic, social, match, training
  
  startDate       DateTime
  endDate         DateTime?
  
  registrationCap Int      @default(64)
  registrationDeadline DateTime
  
  location        String?
  prizePool       Float?
  entryFee        Float?
  
  registrations   EventRegistration[]
  waitlist        EventWaitlist[]
  bracket         TournamentBracket?
  matches         TournamentMatch[]
  reminders       EventReminder[] @relation("reminders")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EventRegistration {
  id              String   @id @default(uuid())
  event           ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  member          ClubMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId        String
  
  registeredAt    DateTime @default(now())
  status          String   @default("registered") // registered, waitlisted, cancelled, withdrawn
  signupOrder     Int // for determining bracket seeding
  
  @@unique([eventId, memberId])
}

model EventWaitlist {
  id              String   @id @default(uuid())
  event           ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  member          ClubMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId        String
  
  position        Int // waitlist position
  addedAt         DateTime @default(now())
  
  @@unique([eventId, memberId])
}

model TournamentBracket {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  event           ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String @unique
  
  bracketType     String   @default("single_elimination") // single_elimination, double_elimination, round_robin, etc.
  totalRounds     Int
  
  matches         TournamentMatch[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TournamentMatch {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  event           ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  bracket         TournamentBracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  bracketId       String
  
  round           Int
  matchPosition   Int
  
  playerA         ClubMember? @relation("matchPlayerA", fields: [playerAId], references: [id])
  playerAId       String?
  playerB         ClubMember? @relation("matchPlayerB", fields: [playerBId], references: [id])
  playerBId       String?
  
  scoreSetA       String? // "6-4,7-5" etc
  scoreSetB       String?
  scoreSetC       String?
  
  winnerId        String? // ClubMember ID
  
  scheduledTime   DateTime?
  court           Court?  @relation(fields: [courtId], references: [id])
  courtId         String?
  
  status          String   @default("pending") // pending, scheduled, in_progress, completed, walked_over
  resultSubmittedAt DateTime?
  resultSubmittedBy String? // Player ID
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== ANNOUNCEMENTS & COMMUNICATIONS ====================

model ClubAnnouncement {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  title           String
  message         String
  announcementType String @default("general") // general, alert, reminder, maintenance, policy
  
  targetRoles     String[] @default(["member"]) // roles this is visible to
  
  createdBy       String? // Player ID
  
  isActive        Boolean  @default(true)
  expiresAt       DateTime?
  
  readBy          String[] @default([]) // list of Player IDs who read this
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model EventReminder {
  id              String   @id @default(uuid())
  event           ClubEvent @relation("reminders", fields: [eventId], references: [id], onDelete: Cascade)
  eventId         String
  
  reminderText    String
  scheduleTime    DateTime // when to send the reminder
  sentAt          DateTime? // when it was actually sent
  
  createdAt       DateTime @default(now())
}

// ==================== CLUB FINANCES ====================

model ClubFinance {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  month           Int      // 1-12
  year            Int
  
  membershipRevenue Float  @default(0)
  courtBookingRevenue Float @default(0)
  coachCommissions Float  @default(0)
  eventRevenue    Float    @default(0)
  
  totalRevenue    Float    @default(0)
  totalExpenses   Float    @default(0)
  netProfit       Float    @default(0)
  
  transactionRecords FinanceTransaction[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, month, year])
}

model FinanceTransaction {
  id              String   @id @default(uuid())
  finance         ClubFinance @relation(fields: [financeId], references: [id], onDelete: Cascade)
  financeId       String
  
  description     String
  category        String   // membership, court_booking, coach_commission, event, expense
  amount          Float
  transactionType String   @default("credit") // credit, debit
  
  relatedToMember ClubMember? @relation(fields: [memberId], references: [id])
  memberId        String?
  
  recordedBy      String? // User/Admin who recorded it
  
  createdAt       DateTime @default(now())
}

// ==================== ROLE-BASED PERMISSIONS ====================

model OrganizationRole {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  name            String   // Admin, Coach, Member, Finance Officer, Guest
  description     String?
  
  permissions     RolePermission[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, name])
}

model RolePermission {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  role            OrganizationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId          String
  
  permissionName  String   // manage_rankings, manage_bookings, manage_members, view_revenue, etc.
  
  createdAt       DateTime @default(now())
  
  @@unique([roleId, permissionName])
}

// ==================== CLUB REPUTATION ====================

model OrganizationBadge {
  id              String   @id @default(uuid())
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String
  
  badgeName       String   // "Verified Club", "High Engagement", "Player Developer", etc.
  badgeType       String   @default("custom") // verified, engagement, development, performance
  achievementDate DateTime @default(now())
  
  createdAt       DateTime @default(now())
}

model ClubRating {
  id              String   @id @default(uuid())
  organization    Organization? @relation(fields: [organizationId], references: [id])
  organizationId  String?
  
  ratedBy         String? // Player ID or anonymous
  rating          Float    // 1-5 stars
  category        String? // facilities, coaching, community, value, overall
  
  comment         String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
