{
  "name": "vico",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "test:all": "npx tsx tests/run-all-tests.ts",
    "test:pilot": "npx tsx tests/run-pilot-scenarios.ts",
    "test:pilot:s1": "npx vitest run tests/pilot-scenarios/01-booking-payment-confirmation.test.ts",
    "test:pilot:s2": "npx vitest run tests/pilot-scenarios/02-double-booking-prevention.test.ts",
    "test:pilot:s3": "npx vitest run tests/pilot-scenarios/03-payment-failure-handling.test.ts",
    "test:pilot:s4": "npx vitest run tests/pilot-scenarios/04-network-timeout-handling.test.ts",
    "test:pilot:s5": "npx vitest run tests/pilot-scenarios/05-admin-bookings-view.test.ts",
    "test:integration": "npx tsx tests/integration/test-courts-api.ts && npx tsx tests/integration/test-dashboard-api.ts && node tests/integration/test-org-members.js && node tests/integration/test-referee-endpoints.js",
    "test:integration:courts": "npx tsx tests/integration/test-courts-api.ts",
    "test:integration:dashboard": "npx tsx tests/integration/test-dashboard-api.ts",
    "test:integration:members": "node tests/integration/test-org-members.js",
    "test:integration:referees": "node tests/integration/test-referee-endpoints.js",
    "test:integration:community": "node tests/integration/test-community-messaging.js",
    "test:coach": "npx tsx tests/coach/test-coach-dashboard.ts",
    "test:coach:debug": "npx tsx tests/coach/test-coach-dashboard-debug.ts",
    "test:coach:direct": "npx tsx tests/coach/test-coach-dashboard-direct.ts",
    "test:coach:load": "npx tsx tests/coach/test-coach-dashboard-load.ts",
    "test:coach:all": "npx tsx tests/coach/test-all-coaches.ts",
    "test:auth": "npx tsx tests/auth/test-elena-login-roles.ts",
    "test:connectivity": "bash tests/connectivity/test-websocket.sh",
    "test:connectivity:socket": "node tests/connectivity/test-socket-connection.js",
    "test:connectivity:websocket": "node tests/connectivity/test-websocket-connection.js",
    "test:connectivity:comments": "bash tests/connectivity/test-comment-reactions.sh",
    "test:data:seed": "node tests/data/test-seed.js",
    "test:stress": "RATE_LIMIT_MAX=5000 RATE_LIMIT_WINDOW_MS=60000 npx tsx tests/run-all-tests.ts --suite all",
    "test:stress:booking": "npx tsx tests/stress/court-booking-stress.ts",
    "test:stress:auth": "npx tsx tests/stress/auth-stress.ts",
    "test:stress:websocket": "npx tsx tests/stress/websocket-stress.ts",
    "test:stress:payment": "npx tsx tests/stress/payment-stress.ts",
    "test:db": "npx tsx tests/test-runner-with-db.ts",
    "test:db:suite": "npx tsx tests/test-runner-with-db.ts --suite",
    "dev": "tsx server.ts",
    "dev:next": "next dev",
    "websocket": "tsx src/websocket-server.ts",
    "websocket:dev": "tsx --watch src/websocket-server.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "migrate": "prisma migrate deploy",
    "seed": "prisma db seed",
    "migrate:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.169.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.16.1",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.2",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "lucide-react": "^0.563.0",
    "next": "15.5.3",
    "next-auth": "^4.24.13",
    "prisma": "^6.16.2",
    "puppeteer": "^23.11.1",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.6.0",
    "react-is": "^19.2.4",
    "recharts": "^3.2.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.17",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
